# Farenheit configuration — copy to .env.local (gitignored) or set in your
# launchd / systemd / Task Scheduler unit. Never commit .env.local.

# Required: absolute path to the folder containing your .epub files.
# BOOKS_DIR=/Users/you/Books

# Optional overrides
# PORT=1111
# HOST=0.0.0.0
# DATA_DIR=./data
# EBOOK_CONVERT=/Applications/calibre.app/Contents/MacOS/ebook-convert

# Optional Basic Auth — when both are set, requests routed through a
# Cloudflare Tunnel (or any reverse proxy that adds cf-connecting-ip)
# require these credentials. Direct LAN connections are not affected.
# Generate a strong password with: openssl rand -base64 24
# FARENHEIT_USER=
# FARENHEIT_PASS=
